<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Apotek Mutiara — Zona Pengiriman JABODETABEK</name>
  <description>Delivery coverage areas for Jakarta, Depok, Bekasi, Tangerang, and Bogor</description>

  <!-- ═══════════════════════════════════════
       STYLES
  ═══════════════════════════════════════ -->
  <Style id="styleJakarta">
    <LineStyle><color>ff0000ff</color><width>2.5</width></LineStyle>
    <PolyStyle><color>400000ff</color></PolyStyle>
  </Style>
  <Style id="styleTangerang">
